# The name of the project
PROJECT_NAME = "NlxStage"

# Use CMake variables (The @ symbols tell CMake to fill these in)
INPUT = "@CMAKE_SOURCE_DIR@/include" "@CMAKE_SOURCE_DIR@/src"

# Where to put the output
OUTPUT_DIRECTORY = "@CMAKE_BINARY_DIR@/docs"

# Doxygen specific settings
RECURSIVE = YES
GENERATE_LATEX = NO
GENERATE_HTML = YES